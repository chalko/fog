#!/usr/bin/env python3
import os
import sys
import json
import subprocess
import time
from datetime import datetime

SHM_DIR = "/dev/shm/fog"
CONFIG_FILE = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "config.env")
TARGETS_FILE = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "targets.json")

def load_config_env():
    config = {}
    if not os.path.exists(CONFIG_FILE):
        return config
    with open(CONFIG_FILE, "r") as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            if line.startswith("export "):
                line = line[len("export "):]
            if "=" in line:
                key, val = line.split("=", 1)
                config[key.strip()] = val.strip("'\"")
    return config

def get_secret(source, key):
    if source == "pass":
        try:
            result = subprocess.run(["pass", "show", key], capture_output=True, text=True, check=True)
            return result.stdout.strip()
        except subprocess.CalledProcessError as e:
            print(f"Error: Failed to retrieve secret from pass for key '{key}'. Details: {e.stderr.strip()}", file=sys.stderr)
            return None
        except FileNotFoundError:
            print("Error: 'pass' command not found. Ensure password-store is installed.", file=sys.stderr)
            return None
    elif source == "vault":
        # Vault command retrieval if needed, otherwise fall back
        try:
            result = subprocess.run(["vault", "kv", "get", "-field=value", key], capture_output=True, text=True, check=True)
            return result.stdout.strip()
        except subprocess.CalledProcessError as e:
            print(f"Error: Failed to retrieve secret from vault for key '{key}'. Details: {e.stderr.strip()}", file=sys.stderr)
            return None
    else:
        print(f"Error: Unsupported secret source '{source}' for key '{key}'", file=sys.stderr)
        return None

def write_cached_env(target, secrets, composites, ttl, config):
    env_file = os.path.join(SHM_DIR, f"{target}-secret.env")
    readme_file = os.path.join(SHM_DIR, f"{target}-README.md")
    ttl_file = os.path.join(SHM_DIR, f"{target}-ttl.txt")

    current_time = int(time.time())
    expiry = current_time + ttl
    expiry_human = datetime.fromtimestamp(expiry).strftime('%Y-%m-%d %H:%M:%S')

    # Prepare variable resolver combining config, retrieved secrets, and environment
    resolver = {}
    resolver.update(config)
    
    # 1. Resolve secrets
    resolved_secrets = {}
    for sec in secrets:
        val = get_secret(sec["source"], sec["key"])
        if val is None:
            print(f"Warning: Skipping target '{target}' due to missing secret '{sec['var']}'", file=sys.stderr)
            return False
        resolved_secrets[sec["var"]] = val
        resolver[sec["var"]] = val

    # 2. Resolve composites
    resolved_composites = {}
    for comp in composites:
        template = comp["template"]
        # Simple placeholder replacement
        val = template
        for k, v in resolver.items():
            placeholder = f"${{{k}}}"
            if placeholder in val:
                val = val.replace(placeholder, v)
        resolved_composites[comp["var"]] = val

    # 3. Write TTL file
    with open(ttl_file, "w") as f:
        f.write(str(expiry))
    os.chmod(ttl_file, 0o600)

    # 4. Write env file with automatic expiration check and self-wiping
    clear_exports = [f"    export {var}=\"\"" for var in list(resolved_secrets.keys()) + list(resolved_composites.keys())]
    clear_exports_str = "\n".join(clear_exports)

    with open(env_file, "w") as f:
        f.write(f"# Cached secrets for {target}. DO NOT EDIT.\n")
        f.write(f"# Generated at {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
        f.write("current_time=$(date +%s)\n")
        f.write(f"expiry=$(cat \"{ttl_file}\" 2>/dev/null || echo 0)\n")
        f.write("if [ \"$current_time\" -ge \"$expiry\" ]; then\n")
        f.write(f"    echo \"Warning: Cached secrets file {env_file} has expired!\" >&2\n")
        f.write("    if [ -n \"${BASH_SOURCE[0]}\" ] && [ -f \"${BASH_SOURCE[0]}\" ]; then\n")
        f.write("        sed -i '/# --- SECRETS START ---/q' \"${BASH_SOURCE[0]}\"\n")
        f.write("        echo \"# Secrets cleared due to expiration.\" >> \"${BASH_SOURCE[0]}\"\n")
        f.write("    fi\n")
        f.write(f"{clear_exports_str}\n")
        f.write("    return 1 2>/dev/null || exit 1\n")
        f.write("fi\n\n")
        f.write("# --- SECRETS START ---\n")
        
        for var, val in resolved_secrets.items():
            f.write(f"export {var}=\"{val}\"\n")
        for var, val in resolved_composites.items():
            f.write(f"export {var}=\"{val}\"\n")
    os.chmod(env_file, 0o600)

    # 5. Write README file
    with open(readme_file, "w") as f:
        f.write(f"# Cached Secrets: {target}\n\n")
        f.write(f"This directory contains cached credentials. Expiry: `{expiry_human}`.\n\n")
        f.write("## Variables Defined\n\n")
        f.write("| Environment Variable | Source Command / Template |\n")
        f.write("| :--- | :--- |\n")
        for sec in secrets:
            cmd = f"pass show {sec['key']}" if sec['source'] == 'pass' else f"vault kv get {sec['key']}"
            f.write(f"| `{sec['var']}` | `{cmd}` |\n")
        for comp in composites:
            f.write(f"| `{comp['var']}` | Template: `{comp['template']}` |\n")
    os.chmod(readme_file, 0o600)

    print(f"Successfully refreshed secrets for '{target}' (TTL: {ttl}s)")
    return True

def write_general_metadata():
    readme_path = os.path.join(SHM_DIR, "README.md")
    agents_path = os.path.join(SHM_DIR, "AGENTS.md")

    # Write README.md
    with open(readme_path, "w") as f:
        f.write(f"# FOG Memory-Cached Secrets Store\n\n")
        f.write(f"This directory (`{SHM_DIR}`) stores memory-cached environment files for active shell sessions.\n\n")
        f.write("## Directory Contents\n\n")
        f.write("- **`*-secret.env`**: Sourced by active shells. These self-check expiration and warning/exit on expiry.\n")
        f.write("- **`*-ttl.txt`**: Unix epoch expiration timestamp.\n")
        f.write("- **`*-README.md`**: Lists variables and the commands used to retrieve them.\n")
        f.write("- **`AGENTS.md`**: Critical instructions for AI agents.\n")
    os.chmod(readme_path, 0o600)

    # Write AGENTS.md
    with open(agents_path, "w") as f:
        f.write("# Agent Instructions\n\n")
        f.write("CRITICAL: Do NOT read any files ending in `-secret.env` or `*-ttl.txt` in this directory. ")
        f.write("Doing so will leak plaintext secrets into your context window and conversation history.\n\n")
        f.write("If you need to know what environment variables are available for a given target, read the ")
        f.write("corresponding `<target>-README.md` file instead. To use these secrets in commands, assume ")
        f.write("they will be sourced by the user or source them in line dynamically inside your execution ")
        f.write("command without printing or reading the secret content.\n")
    os.chmod(agents_path, 0o600)

def main():
    import argparse
    parser = argparse.ArgumentParser(description="Refresh cached environment secrets from pass/vault.")
    parser.add_argument("target", nargs="?", help="Specific target to refresh (e.g., proxmox)")
    parser.add_argument("--all", "-a", action="store_true", help="Refresh all targets defined in targets.json")
    parser.add_argument("--ttl", "-t", type=int, help="TTL in seconds (overrides CACHE_TTL in config.env and defaults to 14400)")

    args = parser.parse_args()

    os.makedirs(SHM_DIR, mode=0o700, exist_ok=True)

    # Load targets specification
    if not os.path.exists(TARGETS_FILE):
        print(f"Error: Targets specification file {TARGETS_FILE} not found.", file=sys.stderr)
        sys.exit(1)
    with open(TARGETS_FILE, "r") as f:
        targets_spec = json.load(f)

    # Determine TTL: command-line arg -> config.env -> default (14400)
    config = load_config_env()
    ttl = 14400
    if args.ttl is not None:
        ttl = args.ttl
    elif "CACHE_TTL" in config:
        try:
            ttl = int(config["CACHE_TTL"])
        except ValueError:
            pass

    if args.all or args.target == "--all":
        targets_to_refresh = list(targets_spec.keys())
    elif args.target in targets_spec:
        targets_to_refresh = [args.target]
    else:
        if not args.target and not args.all:
            parser.print_help()
            sys.exit(1)
        print(f"Error: Unknown target '{args.target}'. Available: {', '.join(targets_spec.keys())} or use --all", file=sys.stderr)
        sys.exit(1)

    success = True
    for target in targets_to_refresh:
        spec = targets_spec[target]
        secrets = spec.get("secrets", [])
        composites = spec.get("composites", [])
        if not write_cached_env(target, secrets, composites, ttl, config):
            success = False

    write_general_metadata()

    if not success:
        sys.exit(1)

if __name__ == "__main__":
    main()
