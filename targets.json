{
  "proxmox": {
    "secrets": [
      {
        "var": "PM_API_TOKEN_SECRET",
        "source": "pass",
        "key": "fog/proxmox/api_token_secret"
      },
      {
        "var": "PM_API_TOKEN_ID",
        "source": "pass",
        "key": "fog/proxmox/api_token_id"
      }
    ],
    "composites": [
      {
        "var": "PROXMOX_VE_API_TOKEN",
        "template": "${PM_API_TOKEN_ID}=${PM_API_TOKEN_SECRET}"
      }
    ]
  },
  "omni": {
    "secrets": [
      {
        "var": "OMNI_SERVICE_ACCOUNT_KEY",
        "source": "pass",
        "key": "fog/omni/service_account_key"
      }
    ]
  },
  "vault": {
    "secrets": [
      {
        "var": "VAULT_TOKEN",
        "source": "pass",
        "key": "fog/vault/root_token"
      }
    ]
  },
  "pihole": {
    "secrets": [
      {
        "var": "PIHOLE_PASSWORD",
        "source": "pass",
        "key": "lodge/heihei/pihole-app"
      }
    ]
  },
  "litellm": {
    "secrets": [
      {
        "var": "LITELLM_MASTER_KEY",
        "source": "vault",
        "key": "secret/app/litellm",
        "field": "master_key"
      }
    ]
  }
}
